# ============================================================
# 脑肿瘤MRI智能辅助诊断系统 - 环境变量配置（示例）
# Brain Tumor MRI Diagnosis System - Environment Variables (Example)
#
# 使用方法：复制为 .env 并修改为实际值
# Usage: cp .env.example .env and edit with real values
# ============================================================

# 数据库配置 (Database)
DB_TYPE=sqlite                    # sqlite（默认，无需安装）或 postgresql
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_NAME=brain_tumor_diagnosis
DB_SQLITE_PATH=brain_tumor.db     # SQLite 文件路径

# JWT 密钥（务必修改为随机字符串！）
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# 服务配置 (Server)
HOST=0.0.0.0
PORT=8000
DEBUG=true
