# ============================================================
# 脑肿瘤MRI智能辅助诊断系统 — 环境变量配置（示例）
# Brain Tumor MRI Intelligent Diagnosis System — Environment Variables (Example)
# ============================================================
# 使用说明：复制为 .env 并填入实际值
# Usage: cp .env.example .env
# ============================================================

# ---- 数据库配置 (Database) ----
# 默认使用 SQLite（无需安装数据库），可选 PostgreSQL
DB_TYPE=sqlite
# SQLite 文件路径（仅 SQLite 模式生效）
DB_SQLITE_PATH=brain_tumor.db
# PostgreSQL（仅 DB_TYPE=postgresql 时生效）
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=your_username
DB_PASSWORD=your_db_password_here
DB_NAME=your_database_name

# ---- JWT 认证 (Authentication) ----
# 生产环境务必更换为随机字符串！
# 生成命令：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-random-secret-key-do-not-use-this-value

# ---- 服务配置 (Server) ----
HOST=127.0.0.1
PORT=8000
DEBUG=false

# ---- 文件上传限制 (Upload) ----
MAX_UPLOAD_SIZE_MB=500
