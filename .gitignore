# ==============================================================================
# 脑肿瘤MRI智能辅助诊断系统 — Git 忽略文件
# ==============================================================================

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# ---- 虚拟环境 ----
venv/
env/
.venv/

# ---- 环境变量（含敏感信息：SECRET_KEY、数据库密码等） ----
.env

# ---- 数据集（BraTS 医学影像，体积巨大，需单独下载） ----
dataset/
backend/dataset/

# ---- 训练产物（日志、checkpoint、对比图体积极大） ----
backend/logs/
backend/.logs/

# ---- 模型权重（>400MB，建议 Git LFS 或网盘链接） ----
backend/checkpoints/
*.pth
!checkpoints/README.md

# ---- 运行时生成文件 ----
backend/uploads/
backend/reports/
*.db
*.sqlite3
backend/eval_results.json

# ---- IDE / 编辑器 ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Node / 前端 ----
frontend/node_modules/
frontend/dist/

# ---- 操作系统 ----
Thumbs.db
.DS_Store

# ---- Jupyter ----
.ipynb_checkpoints/
